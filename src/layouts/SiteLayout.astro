---
import "../styles/global.css";
import type { SiteContent } from "../data/content";

type Props = {
  content: SiteContent;
};

const { content } = Astro.props;
const canonical = new URL(content.path, Astro.site);
const alternate = new URL(content.alternatePath, Astro.site);
---

<!doctype html>
<html lang={content.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={content.meta.description} />
    <meta name="theme-color" content="#f4f4f4" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={content.lang === "en" ? "ja" : "en"} href={alternate} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site)} />
    <title>{content.meta.title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
